# Google C++ Style naming, enforced via readability-identifier-naming.
#   Namespaces     lower_case
#   Types          CamelCase   (classes, structs, enums, aliases)
#   Functions      CamelCase   (snake_case allowed for trivial getters/setters)
#   Variables      lower_case
#   Members        lower_case_ (trailing underscore)
#   Constants      kCamelCase
#
# Enum constants are intentionally NOT checked: they reproduce the SBE
# schema's enumerator names verbatim (e.g. Buy, BIC, nanosecond, nullValue),
# which follow no single C++ convention. Like the strings returned by name(),
# these identifiers are the schema's, not ours, so they are left as-is.
Checks: >-
  -*,
  readability-identifier-naming
WarningsAsErrors: ''
HeaderFilterRegex: '.*'
CheckOptions:
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase
  - key: readability-identifier-naming.EnumCase
    value: CamelCase
  - key: readability-identifier-naming.TypeAliasCase
    value: CamelCase
  - key: readability-identifier-naming.TypedefCase
    value: CamelCase
  - key: readability-identifier-naming.TemplateParameterCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionIgnoredRegexp
    value: '^[a-z_][a-z0-9_]*$'
  - key: readability-identifier-naming.MethodCase
    value: CamelCase
  - key: readability-identifier-naming.MethodIgnoredRegexp
    value: '^[a-z_][a-z0-9_]*$'
  - key: readability-identifier-naming.VariableCase
    value: lower_case
  - key: readability-identifier-naming.ParameterCase
    value: lower_case
  - key: readability-identifier-naming.MemberCase
    value: lower_case
  - key: readability-identifier-naming.PrivateMemberSuffix
    value: _
  - key: readability-identifier-naming.ProtectedMemberSuffix
    value: _
  - key: readability-identifier-naming.ConstexprVariableCase
    value: CamelCase
  - key: readability-identifier-naming.ConstexprVariablePrefix
    value: k
  # EnumConstant* deliberately omitted - see header note (schema-owned names).
